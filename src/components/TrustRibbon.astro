---
/**
 * TrustRibbon — five claims pulled verbatim from the source site's
 * "Why Stylic?" sidebar. Uses .trust-ribbon and .trust-ribbon-item classes
 * defined globally in components.css.
 *
 * Items are passed as a static array so the same component can be reused
 * on inner pages with different (or fewer) claims.
 */

interface RibbonItem {
  label: string;
  /** Inline SVG path data (rendered inside a <svg viewBox="0 0 24 24">) */
  iconPath: string;
}

interface Props {
  /** Optional override; defaults to the source-site five items. */
  items?: RibbonItem[];
}

const defaultItems: RibbonItem[] = [
  {
    label: 'Hand crafted',
    iconPath: '<path d="M12 2L4 6v6c0 5.5 3.6 10.7 8 12 4.4-1.3 8-6.5 8-12V6l-8-4z"/>',
  },
  {
    label: 'We offer 5/10/16 year warranties',
    iconPath: '<circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-6"/>',
  },
  {
    label: 'Established in 1977',
    iconPath: '<path d="M12 6l4 6-4 6-4-6z"/>',
  },
  {
    label: 'Only specialize in cast craft & iron doors',
    iconPath:
      '<path d="M12 6l4 6-4 6-4-6z" opacity="0.3"/><path d="M16 12l4 6-4 6-4-6z"/>',
  },
  
];

const { items = defaultItems } = Astro.props;
---

<section class="sc-1200">
  <div class="trust-ribbon">
    {
      items.map((item) => (
        <div class="trust-ribbon-item">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            set:html={item.iconPath}
          />
          {item.label}
        </div>
      ))
    }
  </div>
</section>
