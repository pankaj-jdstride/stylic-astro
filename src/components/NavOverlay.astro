---
/**
 * NavOverlay — slide-in panel from the right.
 *
 * Triggered by any element with [data-drawer-toggle] (typically the
 * Header's hamburger). Same trigger toggles open/close — the icon
 * morphs between hamburger and X via aria-expanded state.
 *
 * Self-contained: markup, scoped styles, and the open/close script
 * all live here. To use on a page, just include the component once
 * (BaseLayout already does this).
 *
 * Big-link previews use static URLs for the prototype. Replace with
 * paths under /public/images/ once real photography is available.
 */

interface BigLink {
  href: string;
  num: string;
  /** Use {plain} for the leading word and {accent} for the italic-coloured word. */
  plain: string;
  accent: string;
  /** Image URL shown when this link is hovered (desktop only). */
  preview: string;
}

interface SmallLink {
  href: string;
  label: string;
  /** External link? Opens in new tab. */
  external?: boolean;
}

const bigLinks: BigLink[] = [
  {
    href: '/doors-cast-craft-steel.htm',
    num: '01',
    plain: 'Cast Craft',
    accent: 'Steel',
    preview: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=900&q=80',
  },
  {
    href: '/doors-period-steel.htm',
    num: '02',
    plain: 'Period',
    accent: 'Steel',
    preview: 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=900&q=80',
  },
  {
    href: '/doors-victorian.htm',
    num: '03',
    plain: 'Victorian',
    accent: 'Steel',
    preview: 'https://images.unsplash.com/photo-1505691938895-1758d7feb511?auto=format&fit=crop&w=900&q=80',
  },
  {
    href: '/doors-platinum-screen.htm',
    num: '04',
    plain: 'Platinum',
    accent: 'Screen',
    preview: 'https://images.unsplash.com/photo-1572120360610-d971b9d7767c?auto=format&fit=crop&w=900&q=80',
  },
  {
    href: '/keyless-smart-lock.htm',
    num: '+',
    plain: 'Yale',
    accent: 'Keyless Lock',
    preview: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=900&q=80',
  },
  {
    href: '/stylic-handle-set-furniture.htm',
    num: '+',
    plain: 'Handle',
    accent: 'Furniture',
    preview: 'https://images.unsplash.com/photo-1583845112203-29329902332e?auto=format&fit=crop&w=900&q=80',
  },
];

const smallLinks: SmallLink[] = [
  { href: '/services.htm', label: 'Services' },
  { href: '/coating-systems.htm', label: 'Protective Coatings' },
  { href: '/about-security-doors.htm', label: 'Standards' },
  { href: '/warranties.htm', label: 'Warranties' },
  { href: '/showrooms.htm', label: 'Showrooms' },
  { href: '/gallery.htm', label: 'Gallery' },
  { href: '/faq.htm', label: 'FAQ' },
  { href: 'https://g.page/r/Cc8H8caVaBkpEBM/review', label: 'Google Reviews', external: true },
];
---

<!-- Backdrop scrim — clicking it closes the panel. A real DOM element
     (rather than a body::before pseudo) so it can receive click events. -->
<div class="sc-overlay-backdrop" data-drawer-close aria-hidden="true"></div>

<div
  class="sc-overlay"
  id="sc-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Site navigation"
  aria-hidden="true"
>
  <div class="sc-overlay__inner">
    <div class="sc-overlay__head">
      <div class="sc-overlay__head-text">
        <span class="sc-overlay__head-eyebrow">Navigation</span>
        <span class="sc-overlay__head-meta">Established Since 1977</span>
      </div>
      <button
        class="sc-overlay__close"
        type="button"
        aria-label="Close navigation menu"
        data-drawer-close
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <div class="sc-overlay__body">
      <div class="sc-overlay__primary">
        <span class="sc-overlay__col-label">The Range</span>

        {
          bigLinks.map((link) => (
            <a class="sc-overlay__big-link" href={link.href} data-preview={link.preview}>
              <span class="sc-overlay__big-link-num">{link.num}</span>
              <span class="sc-overlay__big-link-text">
                {link.plain} <em>{link.accent}</em>
              </span>
              <span class="sc-overlay__big-link-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>

      <div class="sc-overlay__secondary">
        <span class="sc-overlay__col-label">Information</span>
        <div class="sc-overlay__secondary-list">
          {
            smallLinks.map((link) =>
              link.external ? (
                <a class="sc-overlay__sm-link" href={link.href} target="_blank" rel="noopener">
                  {link.label}
                </a>
              ) : (
                <a class="sc-overlay__sm-link" href={link.href}>
                  {link.label}
                </a>
              ),
            )
          }
        </div>
      </div>
    </div>

    <div class="sc-overlay__foot">
      <div class="sc-overlay__foot-item">
        <span class="sc-overlay__foot-item-label">Phone</span>
        <span class="sc-overlay__foot-item-value">
          <a href="tel:0394653841">(03) 9465 3841</a>
        </span>
      </div>
      <div class="sc-overlay__foot-item">
        <span class="sc-overlay__foot-item-label">Email</span>
        <span class="sc-overlay__foot-item-value">
          <a href="mailto:info@stylicdoors.com.au">info@stylicdoors.com.au</a>
        </span>
      </div>
      <div class="sc-overlay__foot-item">
        <span class="sc-overlay__foot-item-label">Visit</span>
        <span class="sc-overlay__foot-item-value">
          <a href="/showrooms.htm">Schots Home Emporium</a>
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  /* Backdrop scrim — clicking it closes the panel. */
  .sc-overlay-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(20, 18, 15, 0.35);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
    z-index: 89;
    cursor: pointer;
  }
  .sc-overlay-backdrop.is-open {
    opacity: 1;
    visibility: visible;
  }
  :global(body.sc-overlay-open) { overflow: hidden; }

  .sc-overlay {
    position: fixed;
    top: var(--space-80);
    right: var(--space-16);
    bottom: var(--space-32);
    width: min(440px, calc(100vw - 32px));
    max-height: calc(100vh - 112px);
    background: var(--brand-secondary);
    color: var(--white);
    border-radius: var(--card-radius);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4),
                0 8px 24px rgba(0, 0, 0, 0.2);
    z-index: 95;
    transform: translateX(calc(100% + var(--space-16)));
    opacity: 0;
    visibility: hidden;
    transition: transform 0.45s cubic-bezier(0.32, 0.72, 0, 1),
                opacity 0.3s ease,
                visibility 0.45s ease;
    overflow: hidden;
  }
  .sc-overlay.is-open {
    transform: translateX(0);
    opacity: 1;
    visibility: visible;
  }

  /* Atmospheric warm glow at the top — keeps the editorial feel. */
  .sc-overlay::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 140%;
    height: 70%;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--brand-primary) 25%, transparent) 0%,
      transparent 70%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease 0.15s;
  }
  .sc-overlay.is-open::before { opacity: 1; }

  .sc-overlay__inner {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: var(--space-32);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
  }
  .sc-overlay__inner::-webkit-scrollbar { width: 4px; }
  .sc-overlay__inner::-webkit-scrollbar-track { background: transparent; }
  .sc-overlay__inner::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
  }

  /* HEAD */
  .sc-overlay__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-16);
    padding-bottom: var(--space-24);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }
  .sc-overlay__head-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .sc-overlay__head-eyebrow {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--brand-accent-light);
  }
  .sc-overlay__head-meta {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 13px;
    color: var(--grey-400);
  }

  /* Close button — explicit affordance to dismiss the panel.
     Same hairline-circle treatment as the big-link arrows, for consistency. */
  .sc-overlay__close {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease, transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .sc-overlay__close:hover {
    background: var(--brand-accent);
    border-color: var(--brand-accent);
    color: var(--brand-secondary);
    transform: rotate(90deg);
  }
  .sc-overlay__close:focus-visible {
    outline: none;
    border-color: var(--brand-accent-light);
    color: var(--white);
  }

  /* BODY — single column (no horizontal room for two columns) */
  .sc-overlay__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
    padding: var(--space-24) 0;
  }

  /* PRIMARY — door collections as moderately-sized serif links */
  .sc-overlay__primary { display: flex; flex-direction: column; }

  .sc-overlay__col-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--brand-accent-light);
    margin-bottom: var(--space-16);
    display: flex;
    align-items: center;
    gap: var(--space-12);
  }
  .sc-overlay__col-label::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--brand-accent);
  }

  .sc-overlay__big-link {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: var(--space-16);
    padding: var(--space-12) 0;
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.95);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: color 0.3s ease, padding-left 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .sc-overlay__big-link:last-of-type { border-bottom: none; }
  .sc-overlay__big-link-num {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 12px;
    font-weight: 400;
    color: var(--brand-accent-light);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    width: 22px;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  .sc-overlay__big-link-text {
    position: relative;
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1), color 0.3s ease;
  }
  .sc-overlay__big-link-text em {
    font-style: italic;
    font-weight: 400;
    color: var(--brand-accent-light);
  }
  .sc-overlay__big-link-arrow {
    margin-left: auto;
    width: 26px;
    height: 26px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    align-self: center;
    opacity: 0;
    transform: translateX(-8px) rotate(-45deg);
    transition: opacity 0.4s ease,
                transform 0.4s cubic-bezier(0.32, 0.72, 0, 1),
                background 0.3s ease,
                border-color 0.3s ease,
                color 0.3s ease;
  }
  .sc-overlay__big-link-arrow svg { width: 11px; height: 11px; }

  .sc-overlay__big-link:hover { color: var(--white); }
  .sc-overlay__big-link:hover .sc-overlay__big-link-num { opacity: 1; }
  .sc-overlay__big-link:hover .sc-overlay__big-link-text {
    transform: translateX(6px);
    color: var(--brand-accent-light);
  }
  .sc-overlay__big-link:hover .sc-overlay__big-link-arrow {
    opacity: 1;
    transform: translateX(0) rotate(0deg);
    background: var(--brand-accent);
    border-color: var(--brand-accent);
    color: var(--brand-secondary);
  }

  /* SECONDARY — info nav as compact 2-col list */
  .sc-overlay__secondary {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }
  .sc-overlay__secondary-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 var(--space-16);
  }
  .sc-overlay__sm-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-8) 0;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 0.2s ease, padding-left 0.3s ease;
  }
  .sc-overlay__sm-link::after {
    content: '↗';
    font-family: var(--font-heading);
    font-size: 12px;
    opacity: 0;
    transform: translate(-3px, 3px);
    transition: opacity 0.2s ease, transform 0.3s ease;
    color: var(--brand-accent-light);
  }
  .sc-overlay__sm-link:hover {
    color: var(--white);
    padding-left: var(--space-8);
  }
  .sc-overlay__sm-link:hover::after {
    opacity: 1;
    transform: translate(0, 0);
  }

  /* FOOT — contact strip stacked */
  .sc-overlay__foot {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding-top: var(--space-20);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }
  .sc-overlay__foot-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-12);
  }
  .sc-overlay__foot-item-label {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--grey-400);
    width: 50px;
    flex-shrink: 0;
  }
  .sc-overlay__foot-item-value {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 400;
    color: var(--white);
  }
  .sc-overlay__foot-item-value a {
    color: inherit;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }
  .sc-overlay__foot-item-value a:hover {
    border-color: var(--brand-accent-light);
    color: var(--brand-accent-light);
  }

  /* Stagger-in animation */
  .sc-overlay__head,
  .sc-overlay__col-label,
  .sc-overlay__big-link,
  .sc-overlay__secondary-list,
  .sc-overlay__foot {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .sc-overlay.is-open .sc-overlay__head             { opacity: 1; transform: none; transition-delay: 0.15s; }
  .sc-overlay.is-open .sc-overlay__col-label        { opacity: 1; transform: none; transition-delay: 0.22s; }
  .sc-overlay.is-open .sc-overlay__big-link:nth-of-type(1) { opacity: 1; transform: none; transition-delay: 0.26s; }
  .sc-overlay.is-open .sc-overlay__big-link:nth-of-type(2) { opacity: 1; transform: none; transition-delay: 0.30s; }
  .sc-overlay.is-open .sc-overlay__big-link:nth-of-type(3) { opacity: 1; transform: none; transition-delay: 0.34s; }
  .sc-overlay.is-open .sc-overlay__big-link:nth-of-type(4) { opacity: 1; transform: none; transition-delay: 0.38s; }
  .sc-overlay.is-open .sc-overlay__big-link:nth-of-type(5) { opacity: 1; transform: none; transition-delay: 0.42s; }
  .sc-overlay.is-open .sc-overlay__big-link:nth-of-type(6) { opacity: 1; transform: none; transition-delay: 0.46s; }
  .sc-overlay.is-open .sc-overlay__secondary-list   { opacity: 1; transform: none; transition-delay: 0.34s; }
  .sc-overlay.is-open .sc-overlay__foot             { opacity: 1; transform: none; transition-delay: 0.50s; }

  @media (max-width: 720px) {
    .sc-overlay {
      top: 72px;
      right: var(--space-12);
      left: var(--space-12);
      bottom: var(--space-16);
      width: auto;
      max-height: calc(100vh - 88px);
    }
    .sc-overlay__inner { padding: var(--space-24); }
    .sc-overlay__big-link { font-size: 22px; }
    .sc-overlay__secondary-list { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .sc-overlay__big-link-num { width: 18px; font-size: 11px; }
    .sc-overlay__big-link-arrow { display: none; }
  }
</style>

<script>
  // Drawer behaviour: open / close / Escape / focus management.
  // Vanilla JS — Astro will bundle this and inline it; no framework needed.
  (function () {
    const overlay = document.getElementById('sc-drawer');
    const backdrop = document.querySelector<HTMLElement>('.sc-overlay-backdrop');
    const toggle = document.querySelector<HTMLButtonElement>('[data-drawer-toggle]');
    if (!overlay || !backdrop || !toggle) return;

    const bigLinks = overlay.querySelectorAll<HTMLAnchorElement>('.sc-overlay__big-link');
    const smLinks = overlay.querySelectorAll<HTMLAnchorElement>('.sc-overlay__sm-link');
    // Every element marked data-drawer-close (in-panel X button + backdrop)
    // dismisses the panel.
    const closers = document.querySelectorAll<HTMLElement>('[data-drawer-close]');
    let lastFocus: HTMLElement | null = null;

    const isOpen = () => overlay.classList.contains('is-open');

    function open() {
      lastFocus = document.activeElement as HTMLElement | null;
      overlay!.classList.add('is-open');
      backdrop!.classList.add('is-open');
      overlay!.setAttribute('aria-hidden', 'false');
      toggle!.setAttribute('aria-expanded', 'true');
      toggle!.setAttribute('aria-label', 'Close navigation menu');
      document.body.classList.add('sc-overlay-open');
      const firstLink = overlay!.querySelector<HTMLAnchorElement>('.sc-overlay__big-link');
      if (firstLink) firstLink.focus();
    }

    function close() {
      overlay!.classList.remove('is-open');
      backdrop!.classList.remove('is-open');
      overlay!.setAttribute('aria-hidden', 'true');
      toggle!.setAttribute('aria-expanded', 'false');
      toggle!.setAttribute('aria-label', 'Open navigation menu');
      document.body.classList.remove('sc-overlay-open');
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    toggle.addEventListener('click', () => {
      if (isOpen()) close();
      else open();
    });

    closers.forEach((el) => el.addEventListener('click', close));
    bigLinks.forEach((link) => link.addEventListener('click', close));
    smLinks.forEach((link) => link.addEventListener('click', close));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close();
    });
  })();
</script>
